#include<iostream>
using namespace std;

int main() {

    int choice;

    cout << "1. Insert at Beginning\n";
    cout << "2. Insert at Middle\n";
    cout << "3. Insert at End\n";
    cout << "4. Delete from Beginning\n";
    cout << "5. Delete from Middle\n";
    cout << "6. Delete from End\n";

    cout << "\nEnter Choice : ";
    cin >> choice;

    switch(choice) {

        // INSERT AT BEGINNING
        case 1: {

            int arr[6] = {4,5,8,2,1};
            int ele = 10;

            for(int i = 4; i >= 0; i--) {
                arr[i + 1] = arr[i];
            }

            arr[0] = ele;

            cout << "\nAfter Insertion:\n";

            for(int i = 0; i < 6; i++) {
                cout << arr[i] << " ";
            }

            break;
        }

        // INSERT AT MIDDLE
        case 2: {

            int arr[6] = {4,5,8,2,1};
            int ele = 10;
            int pos = 2;

            for(int i = 4; i >= pos; i--) {
                arr[i + 1] = arr[i];
            }

            arr[pos] = ele;

            cout << "\nAfter Insertion:\n";

            for(int i = 0; i < 6; i++) {
                cout << arr[i] << " ";
            }

            break;
        }

        // INSERT AT END
        case 3: {

            int arr[6] = {4,5,8,2,1};
            int ele = 10;

            arr[5] = ele;

            cout << "\nAfter Insertion:\n";

            for(int i = 0; i < 6; i++) {
                cout << arr[i] << " ";
            }

            break;
        }

        // DELETE FROM BEGINNING
        case 4: {

            int arr[5] = {4,5,8,2,1};

            for(int i = 0; i < 4; i++) {
                arr[i] = arr[i + 1];
            }

            cout << "\nAfter Deletion:\n";

            for(int i = 0; i < 4; i++) {
                cout << arr[i] << " ";
            }

            break;
        }

        // DELETE FROM MIDDLE
        case 5: {

            int arr[5] = {4,5,8,2,1};
            int pos = 2;

            for(int i = pos; i < 4; i++) {
                arr[i] = arr[i + 1];
            }

            cout << "\nAfter Deletion:\n";

            for(int i = 0; i < 4; i++) {
                cout << arr[i] << " ";
            }

            break;
        }

        // DELETE FROM END
        case 6: {

            int arr[5] = {4,5,8,2,1};

            cout << "\nAfter Deletion:\n";

            for(int i = 0; i < 4; i++) {
                cout << arr[i] << " ";
            }

            break;
        }

        default:
            cout << "Invalid Choice";
    }

    return 0;
}
